{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install MCP Servers",
            "type": "shell",
            "command": "claude",
            "args": [
                "mcp",
                "add",
                "--transport",
                "sse",
                "context7",
                "-s",
                "user",
                "--",
                "npx",
                "-y",
                "@context7/mcp-server"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Install Cloudflare MCP",
            "type": "shell",
            "command": "claude",
            "args": [
                "mcp",
                "add",
                "--transport",
                "sse",
                "cf-docs",
                "-s",
                "user",
                "--",
                "npx",
                "-y",
                "@cloudflare/mcp-server-docs-vectorize"
            ],
            "group": "build"
        },
        {
            "label": "Install Chrome Devtools MCP",
            "type": "shell",
            "command": "claude",
            "args": [
                "mcp",
                "add",
                "--transport",
                "stdio",
                "chrome-devtools",
                "-s",
                "user",
                "--",
                "npx",
                "-y",
                "@chrome-devtools/mcp-server"
            ],
            "group": "build"
        }
    ]
}
