{
  "manifest_version": 3,
  "name": "Sabar Msports Parser",
  "version": "2.2",
  "description": "Alat parsing data msports.ms0198.com untuk project Sabar - Auto Sync",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://msports.ms0198.com/*", "http://localhost/*", "http://127.0.0.1/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://msports.ms0198.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "all_frames": true
    }
  ]
}